# LLM (DashScope / 通义千问)
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 图片生成 (火山引擎 Seedream)
VOLCANO_API_KEY=your_volcano_api_key
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_IMAGE_MODEL=doubao-seedream-4-0-250828
VOLCANO_EDIT_MODEL=doubao-seedream-4-0-250828

# 数据库 (MySQL)
DATABASE_URL=mysql+aiomysql://canvasflow:canvasflow_pwd@127.0.0.1:3306/canvasflow

# 对象存储 (MinIO)
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_Adm1n_S3cure!
MINIO_BUCKET=canvasflow
MINIO_SECURE=false

# Agent
RECURSION_LIMIT=200

# 认证 (设置 AUTH_ENABLED=true 启用登录功能)
AUTH_ENABLED=false
AUTH_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
AUTH_TOKEN_EXPIRY_HOURS=72
AUTH_COOKIE_SECURE=auto
AUTH_COOKIE_DOMAIN=
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=canvasflow123

# 日志
LOG_LEVEL=INFO
